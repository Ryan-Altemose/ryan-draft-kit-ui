# Backend URL for the separate Draft Kit backend service.
# Prefer BACKEND_URL on the server so it is not exposed to the browser.
BACKEND_URL=https://team-white-draft-kit-ui-backend.onrender.com
NEXT_PUBLIC_BACKEND_URL=
BACKEND_INTERNAL_AUTH_SECRET=your-internal-auth-secret

# External player/stats API URL.
NEXT_PUBLIC_API_URL=https://fantasy-baseball-api.onrender.com

# Auth.js configuration.
AUTH_SECRET=your-auth-secret
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Optional API key header. Prefer API_KEY on the server when your deployment enforces it.
API_KEY=your-api-key-here
NEXT_PUBLIC_API_KEY=
